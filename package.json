{
  "name": "pallet-estimator",
  "version": "0.1.0",
  "description": "Estimate pallet/skid dimensions and weights from a shipment's material list (PDF) using Claude (Opus 4.8), calibrated on real example shipments stored in MongoDB.",
  "type": "module",
  "main": "src/router.js",
  "exports": {
    ".": "./src/router.js",
    "./router": "./src/router.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "ingest": "node scripts/ingest-examples.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mongodb": "^6.12.0",
    "pdf-parse": "^2.4.5",
    "zod": "^3.24.1"
  }
}
