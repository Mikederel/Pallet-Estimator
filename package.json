{
  "name": "pallet-estimator",
  "version": "0.1.0",
  "description": "Estimate the number of shipping pallets needed from a material list, using Claude (Opus 4.8) with few-shot examples stored in MongoDB.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node scripts/seed-examples.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mongodb": "^6.12.0",
    "zod": "^3.24.1"
  }
}
