# Anthropic API key (get one at https://console.anthropic.com) — REQUIRED.
# This is a separate key from Claude Code.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# MongoDB connection (local instance on the server).
MONGODB_URI=mongodb://127.0.0.1:27017

# PORT and DB_NAME are normally provided by the PM2 ecosystem files
# (ecosystem.config.cjs = prod :3004, ecosystem.dev.config.cjs = dev :3005).
# Uncomment only if you run the app directly with `npm start` / `npm run dev`.
# PORT=3005
# DB_NAME=pallet-estimator-dev
